    "pnoTestErrorCity1024, pnoSDFTimeCity1024, pnoVTimeCity1024, pnoTotalTimeCity1024 = test_model(modelPNO, mask_func_arr[2],testDataCity1024, \"PNO\",sdfModel = modelSDF, numTimeInst=numTimeInst)\n",
